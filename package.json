{
  "name": "@stackfactor/client-api",
  "version": "1.1.147",
  "description": "Node.js library for the StackFactor API",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "declarations",
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:watch": "tsc --watch",
    "test": "jest",
    "lint": "eslint 'src/**/*.{ts,tsx}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StackFactor/stackfactor-client-api.git"
  },
  "author": "StackFactor Inc",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/StackFactor/stackfactor-client-api/issues"
  },
  "homepage": "https://github.com/StackFactor/stackfactor-client-api#readme",
  "dependencies": {
    "axios": "^1.8.1",
    "dotenv": "^16.4.7",
    "html2plaintext": "^2.1.4",
    "https": "latest",
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.3"
  }
}
